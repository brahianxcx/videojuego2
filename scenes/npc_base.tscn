[node name="NPC_base" type="Node2D"]
script = ExtResource("1_pn5ta")
dialogue_text = "¡Vaya, vaya! Miren quién decidió aparecer. ¿El \"héroe\" local? No me hagas reír. Llegas demasiado tarde. Marinilla ya es nuestra, y pronto todo el camino hasta Medellín caerá bajo nuestro control.

Mis jefes ya se han apoderado de cada rincón de esta zona. Así que da media vuelta y vuelve por donde viniste si no quieres que te aplaste aquí mismo. ¡Esta ciudad ya tiene nuevos dueños!"

